.page {
  min-height: 100vh;
  padding: 20rpx;
}

.tool-card {
  border: 1rpx solid rgba(23, 32, 27, 0.08);
  border-radius: 32rpx;
  background: #fffdf8;
  box-shadow: 0 18rpx 52rpx rgba(33, 48, 39, 0.12);
  padding: 32rpx;
}

.hero {
  margin-bottom: 32rpx;
}

.title {
  display: block;
  color: #17201b;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1.1;
}

.blessing {
  display: block;
  margin-top: 12rpx;
  color: #0c9c55;
  font-size: 28rpx;
  font-weight: 900;
}

.time-grid,
.money-grid,
.rule-list {
  display: flex;
  gap: 16rpx;
}

.time-grid,
.money-grid {
  flex-wrap: wrap;
}

.date-button {
  flex: 1;
  min-width: 280rpx;
  min-height: 136rpx;
  border: 1rpx solid #e1ded4;
  border-radius: 24rpx;
  background: #ffffff;
  color: #17201b;
  padding: 20rpx;
  text-align: left;
}

.date-button::after,
.rule-option::after,
.preview-button::after,
.template-button::after,
.sheet button::after,
.modal-head button::after {
  border: 0;
}

.date-button text:first-child {
  display: block;
  color: #717970;
  font-size: 26rpx;
  font-weight: 900;
}

.date-button view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.date-value {
  color: #17201b !important;
  font-size: 36rpx !important;
  font-weight: 950 !important;
  line-height: 1;
}

.chevron {
  color: #0c9c55;
  font-size: 34rpx;
  font-weight: 900;
}

.money-grid,
.rule-section,
.result-box,
.preview-button,
.template-button {
  margin-top: 24rpx;
}

.field > text {
  display: block;
  margin-bottom: 12rpx;
  color: #3b453e;
  font-size: 28rpx;
  font-weight: 900;
}

.field {
  flex: 1;
  min-width: 280rpx;
}

.inline-input {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  border: 1rpx solid #e1ded4;
  border-radius: 24rpx;
  background: #ffffff;
  overflow: hidden;
}

.inline-input input {
  flex: 1;
  min-width: 0;
  color: #17201b;
  font-size: 36rpx;
  font-weight: 900;
  padding: 0 24rpx;
}

.inline-input text {
  flex: 0 0 auto;
  color: #717970;
  font-size: 26rpx;
  font-weight: 900;
  padding-right: 24rpx;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #17201b;
  font-size: 32rpx;
  font-weight: 900;
}

.rule-option {
  display: flex;
  flex: 1;
  min-width: 0;
  min-height: 172rpx;
  border: 1rpx solid #e1ded4;
  border-radius: 24rpx;
  background: #ffffff;
  color: #17201b;
  padding: 18rpx;
  text-align: left;
}

.rule-option-active {
  border-color: #17c96d;
  background: #f0fff6;
}

.radio-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 46rpx;
  height: 46rpx;
  margin-right: 14rpx;
  border: 1rpx solid #d2d8d1;
  border-radius: 50%;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.rule-option-active .radio-dot {
  border-color: #17c96d;
  background: #17c96d;
}

.rule-name {
  display: block;
  color: #17201b;
  font-size: 30rpx;
  font-weight: 900;
}

.rule-detail {
  display: block;
  margin-top: 8rpx;
  color: #717970;
  font-size: 24rpx;
  line-height: 1.3;
}

.result-box {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  border-radius: 28rpx;
  background: #17201b;
  color: #dbe9df;
  padding: 32rpx;
}

.result-box > text {
  color: #dbe9df;
  font-size: 30rpx;
  font-weight: 800;
}

.strong {
  color: #ffffff;
  font-weight: 950;
}

.net-line {
  color: #77f2ad !important;
  font-size: 38rpx !important;
  font-weight: 950 !important;
}

.preview-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  border: 1rpx solid #e1ded4;
  border-radius: 28rpx;
  background: #ffffff;
  color: #17201b;
  padding: 0 28rpx;
  font-size: 30rpx;
  font-weight: 950;
}

.mode-pill {
  border-radius: 999rpx;
  background: #e9f8ef;
  color: #0c9c55;
  font-size: 24rpx;
  font-weight: 900;
  padding: 8rpx 16rpx;
}

.template-button {
  width: 100%;
  min-height: 104rpx;
  border: 0;
  border-radius: 28rpx;
  background: #17c96d;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 950;
  box-shadow: 0 12rpx 24rpx rgba(23, 201, 109, 0.22);
}

.sheet-backdrop,
.modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 10;
  background: rgba(16, 22, 18, 0.38);
}

.sheet-backdrop {
  display: flex;
  align-items: flex-end;
  padding: 24rpx;
}

.sheet {
  width: 100%;
  border-radius: 36rpx;
  background: #fffdf8;
  padding: 28rpx;
  box-shadow: 0 20rpx 70rpx rgba(13, 19, 15, 0.28);
}

.sheet-head,
.modal-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.sheet-head > text,
.modal-title {
  color: #17201b;
  font-size: 36rpx;
  font-weight: 950;
}

.sheet-head button,
.modal-head button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #f2f1eb;
  color: #17201b;
  font-size: 40rpx;
  line-height: 1;
  padding: 0;
}

.picker-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 24rpx;
}

.picker-column {
  display: flex;
  width: 100%;
  min-height: 96rpx;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  border: 1rpx solid #e1ded4;
  border-radius: 24rpx;
  background: #ffffff;
  padding: 14rpx 18rpx;
}

.picker-label {
  flex: 0 0 54rpx;
  color: #717970;
  font-size: 24rpx;
  font-weight: 900;
}

.picker-column button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #edf8f1;
  color: #0c9c55;
  font-size: 32rpx;
  font-weight: 900;
  padding: 0;
}

.picker-value {
  display: flex;
  flex: 1;
  min-width: 0;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
}

.picker-value input {
  width: 132rpx;
  color: #17201b;
  font-size: 30rpx;
  font-weight: 950;
  text-align: right;
}

.picker-value text {
  color: #17201b;
  font-size: 24rpx;
  font-weight: 950;
}

.sheet-confirm {
  width: 100%;
  min-height: 96rpx;
  margin-top: 24rpx;
  border-radius: 24rpx;
  background: #17c96d;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 950;
}

.modal-backdrop {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
}

.preview-modal {
  width: 100%;
  max-width: 640rpx;
  border-radius: 36rpx;
  background: #fffdf8;
  padding: 28rpx;
  box-shadow: 0 22rpx 72rpx rgba(13, 19, 15, 0.3);
}

.preview-modal .mode-pill {
  display: inline-block;
  margin-top: 10rpx;
}

.report-text {
  display: block;
  margin-top: 24rpx;
  border-radius: 20rpx;
  background: #f7f7f3;
  color: #17201b;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.7;
  white-space: pre-wrap;
}

.official-note {
  display: block;
  margin-top: 20rpx;
  color: #717970;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.55;
}

@media (max-width: 390px) {
  .time-grid,
  .money-grid {
    flex-direction: column;
  }

  .rule-list {
    flex-direction: column;
  }
}
